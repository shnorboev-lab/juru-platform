# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://juru:juru_secret@localhost:5432/juru_perf"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"
# Restrict login to juru.org domain
ALLOWED_DOMAIN="juru.org"

JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_REFRESH_SECRET="change-this-refresh-secret-too"

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001
API_BASE_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# ── Email (SMTP via Google Workspace) ─────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@juru.org"
SMTP_PASS="your-gmail-app-password"
EMAIL_FROM="Juru HR <noreply@juru.org>"

# ── Google Chat Webhook ────────────────────────────────────────────────────────
GCHAT_WEBHOOK_URL="https://chat.googleapis.com/v1/spaces/YOUR_SPACE/messages?key=..."

# ── Object Storage (MinIO / S3) ───────────────────────────────────────────────
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="juru-reports"

# ── Node env ──────────────────────────────────────────────────────────────────
NODE_ENV="development"
